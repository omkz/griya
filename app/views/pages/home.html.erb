<div class="bg-white">
  <!-- Hero Section -->
  <div class="relative bg-blue-900 py-24 px-6 sm:py-32 lg:px-8 overflow-hidden">
    <div class="absolute inset-0 opacity-20">
      <div class="absolute inset-0 bg-gradient-to-r from-blue-800 to-indigo-900 mix-blend-multiply"></div>
      <!-- Decorative pattern or image could go here -->
    </div>
    
    <div class="relative max-w-2xl mx-auto text-center">
      <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-6xl">
        Temukan Hunian Impian di <span class="text-blue-400">Jogja</span>
      </h1>
      <p class="mt-6 text-lg leading-8 text-blue-100">
        Pilihan properti terbaik di Bangunjiwo dan sekitarnya. Aman, Terpercaya, dan Tanpa Ribet.
      </p>
      
      <!-- Search Bar Placeholder -->
      <div class="mt-10 max-w-xl mx-auto">
        <div class="relative">
          <input type="text" placeholder="Cari area, tipe rumah, atau harga..." 
                 class="block w-full rounded-2xl border-0 py-4 px-6 pr-16 text-gray-900 shadow-2xl ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-blue-500 sm:text-sm sm:leading-6">
          <div class="absolute inset-y-2 right-2 flex items-center">
            <button class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-xl font-bold transition">Cari</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="flex items-end justify-between mb-10">
      <div>
        <h2 class="text-3xl font-black text-gray-900 tracking-tight">Properti Terbaru</h2>
        <p class="text-gray-500 mt-2">Listing paling hangat di Bangunjiwo</p>
      </div>
      <%= link_to "Lihat Semua →", properties_path, class: "text-blue-600 font-bold hover:text-blue-800 transition" %>
    </div>

    <% if @featured_properties.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <% @featured_properties.each do |property| %>
          <%= link_to property_path(property), class: "group bg-white border border-gray-100 rounded-3xl overflow-hidden shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300" do %>
            <!-- Image Area -->
            <div class="relative h-64 bg-gray-200 overflow-hidden">
              <% if property.images.attached? %>
                <%= image_tag property.images.first, class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" %>
              <% else %>
                <div class="w-full h-full flex items-center justify-center text-gray-400 font-bold">
                  NO IMAGE
                </div>
              <% end %>
              <div class="absolute top-4 left-4">
                <span class="bg-white/90 backdrop-blur px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest text-blue-600 shadow-sm">
                  <%= property.listing_type.humanize %>
                </span>
              </div>
            </div>

            <!-- Content Area -->
            <div class="p-6">
              <div class="flex justify-between items-start mb-2">
                <h3 class="text-xl font-bold text-gray-900 group-hover:text-blue-600 transition truncate"><%= property.title %></h3>
              </div>
              <p class="text-sm text-gray-500 flex items-center gap-1 mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                </svg>
                <%= property.region.name %>
              </p>
              
              <div class="flex items-center justify-between mt-6 pt-4 border-t border-gray-50">
                <p class="text-xl font-black text-blue-600">
                  <%= number_to_currency(property.price, unit: "Rp ", delimiter: ".", precision: 0) %>
                </p>
                <span class="text-xs font-bold text-gray-400 uppercase tracking-tighter"><%= property.property_type.humanize %></span>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="py-24 text-center border-2 border-dashed border-gray-200 rounded-3xl">
        <div class="mx-auto w-20 h-20 bg-gray-50 rounded-full flex items-center justify-center mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
          </svg>
        </div>
        <p class="text-gray-500 font-medium">Belum ada properti aktif.</p>
        <p class="text-sm text-gray-400 mt-1">Coba jalankan data seed atau tambah properti baru.</p>
      </div>
    <% end %>
  </div>
</div>

