<div class="container mx-auto p-8">
  <h1 class="text-3xl font-bold mb-8 text-blue-600">GRIYA JOGJA</h1>

  <% if @featured_properties.any? %>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <% @featured_properties.each do |property| %>
        <div class="border rounded-xl p-4 shadow-sm bg-white">
          <div class="h-40 bg-gray-200 rounded-lg mb-4 flex items-center justify-center text-gray-400 font-bold">
            NO IMAGE
          </div>
          <h2 class="text-xl font-bold"><%= property.title %></h2>
          <p class="text-blue-600 font-bold">
            <%= number_to_currency(property.price, unit: "Rp ", delimiter: ".", precision: 0) %>
          </p>
          <div class="mt-2 flex gap-2">
            <span class="text-xs bg-gray-100 px-2 py-1 rounded"><%= property.listing_type.humanize %></span>
            <span class="text-xs bg-gray-100 px-2 py-1 rounded"><%= property.property_type.humanize %></span>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="p-20 text-center border-2 border-dashed rounded-2xl">
      <p class="text-gray-500 italic">Belum ada properti di Bangunjiwo. Coba jalankan db:seed, Om!</p>
    </div>
  <% end %>
</div>
