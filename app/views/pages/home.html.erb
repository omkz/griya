<div class="bg-white">
  <!-- Hero Section -->
  <div class="relative bg-blue-900 py-24 px-6 sm:py-32 lg:px-8 overflow-hidden">
    <div class="absolute inset-0 opacity-20">
      <div class="absolute inset-0 bg-gradient-to-r from-blue-800 to-indigo-900 mix-blend-multiply"></div>
    </div>
    
    <div class="relative max-w-2xl mx-auto text-center">
      <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-6xl text-balance">
        Temukan Hunian Impian di <span class="text-blue-400">Jogja</span>
      </h1>
      <p class="mt-6 text-lg leading-8 text-blue-100">
        Pilihan properti terbaik di Bangunjiwo dan sekitarnya. Aman, Terpercaya, dan Tanpa Ribet.
      </p>
      
      <!-- Search Bar -->
      <div class="mt-10 max-w-xl mx-auto">
        <form action="<%= properties_path %>" method="get" class="relative">
          <input type="text" name="query" placeholder="Cari area, tipe rumah, atau harga..." 
                 class="block w-full rounded-2xl border-0 py-4 px-6 pr-16 text-gray-900 shadow-2xl ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-blue-500 sm:text-sm sm:leading-6">
          <div class="absolute inset-y-2 right-2 flex items-center">
            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-xl font-bold transition">Cari</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Categories Section -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 -mt-10 relative z-10">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <% [["Rumah", "house", "🏠"], ["Tanah", "land", "🌳"], ["Apartemen", "apartment", "🏢"], ["Komersial", "commercial", "🏪"]].each do |name, type, icon| %>
        <%= link_to properties_path(type: type), class: "bg-white p-6 rounded-2xl shadow-lg border border-gray-100 flex flex-col items-center hover:shadow-xl hover:-translate-y-1 transition group" do %>
          <span class="text-3xl mb-2 group-hover:scale-110 transition shrink-0"><%= icon %></span>
          <span class="font-bold text-gray-900"><%= name %></span>
        <% end %>
      <% end %>
    </div>
  </div>

  <!-- Featured Section (Pilihan Kami) -->
  <% if @featured_properties.any? %>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <div class="text-center mb-12">
        <h2 class="text-sm font-bold text-blue-600 uppercase tracking-widest mb-2">Eksklusif</h2>
        <h3 class="text-4xl font-black text-gray-900 italic">Pilihan Kami</h3>
        <p class="text-gray-500 mt-2">Properti terbaik dengan legalitas terjamin dan lokasi strategis.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <% @featured_properties.each do |property| %>
          <%= link_to property_path(property), class: "group relative rounded-3xl overflow-hidden aspect-[16/9] shadow-2xl" do %>
            <div class="absolute inset-0 bg-gray-200">
              <% if property.images.attached? %>
                <%= image_tag property.images.first, class: "w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" %>
              <% else %>
                <div class="w-full h-full flex items-center justify-center text-gray-400 font-bold bg-gradient-to-br from-gray-100 to-gray-200">NO IMAGE</div>
              <% end %>
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
            <div class="absolute bottom-0 left-0 p-8">
              <span class="bg-blue-600 text-white text-[10px] font-black px-3 py-1 rounded-full uppercase mb-3 inline-block tracking-tighter shadow-lg">Featured</span>
              <h4 class="text-2xl font-bold text-white mb-2"><%= property.title %></h4>
              <p class="text-blue-300 font-black text-xl">
                <%= number_to_currency(property.price, unit: "Rp ", delimiter: ".", precision: 0) %>
              </p>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Why Us Section -->
  <div class="bg-gray-50 py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 text-center">
        <div>
          <div class="w-16 h-16 bg-blue-100 text-blue-600 rounded-2xl flex items-center justify-center mx-auto mb-6 text-2xl">🛡️</div>
          <h4 class="text-xl font-bold mb-3">Legalitas Aman</h4>
          <p class="text-gray-500">Semua properti telah melalui verifikasi dokumen dan status tanah.</p>
        </div>
        <div>
          <div class="w-16 h-16 bg-green-100 text-green-600 rounded-2xl flex items-center justify-center mx-auto mb-6 text-2xl">🤝</div>
          <h4 class="text-xl font-bold mb-3">Tanpa Perantara Ribet</h4>
          <p class="text-gray-500">Hubungi agen langsung via WhatsApp dengan respon cepat.</p>
        </div>
        <div>
          <div class="w-16 h-16 bg-orange-100 text-orange-600 rounded-2xl flex items-center justify-center mx-auto mb-6 text-2xl">📍</div>
          <h4 class="text-xl font-bold mb-3">Spesialis Jogja Selatan</h4>
          <p class="text-gray-500">Fokus pada Bangunjiwo dan sekitarnya untuk data yang lebih akurat.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Latest Section -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="flex items-end justify-between mb-12">
      <div>
        <h2 class="text-3xl font-black text-gray-900 tracking-tight">Listing Terbaru</h2>
        <p class="text-gray-500 mt-2">Daftar properti yang baru saja bergabung.</p>
      </div>
      <%= link_to "Lihat Semua →", properties_path, class: "text-blue-600 font-bold hover:text-blue-800 transition" %>
    </div>

    <% if @latest_properties.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <% @latest_properties.each do |property| %>
          <%= link_to property_path(property), class: "group bg-white border border-gray-100 rounded-3xl overflow-hidden shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300" do %>
            <div class="relative h-64 bg-gray-200 overflow-hidden">
              <% if property.images.attached? %>
                <%= image_tag property.images.first, class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" %>
              <% else %>
                <div class="w-full h-full flex items-center justify-center text-gray-400 font-bold bg-gray-100">NO IMAGE</div>
              <% end %>
              <div class="absolute top-4 left-4">
                <span class="bg-white/95 backdrop-blur px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest text-blue-600 shadow-sm">
                  <%= property.listing_type.humanize %>
                </span>
              </div>
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-gray-900 group-hover:text-blue-600 transition truncate mb-1"><%= property.title %></h3>
              <p class="text-sm text-gray-500 flex items-center gap-1 mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                </svg>
                <%= property.region.name %>
              </p>
              <div class="flex items-center justify-between mt-6 pt-4 border-t border-gray-50">
                <p class="text-xl font-black text-blue-600">
                  <%= number_to_currency(property.price, unit: "Rp ", delimiter: ".", precision: 0) %>
                </p>
                <span class="text-[10px] font-black text-gray-400 uppercase tracking-tighter"><%= property.property_type.humanize %></span>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="py-24 text-center border-2 border-dashed border-gray-200 rounded-3xl">
        <p class="text-gray-500 font-medium">Belum ada properti aktif.</p>
      </div>
    <% end %>
  </div>
</div>


