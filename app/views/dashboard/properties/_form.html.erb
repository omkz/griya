<%= form_with(model: [:dashboard, property], class: "space-y-8") do |f| %>
  <% if property.errors.any? %>
    <div class="p-4 bg-red-50 border-l-4 border-red-400 text-red-700 rounded-lg mb-8">
      <p class="font-bold underline mb-2">Terjadi kesalahan:</p>
      <ul class="list-disc pl-5">
        <% property.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 text-balance">
    <!-- Section 1: Basic Info -->
    <div class="space-y-6">
      <div class="bg-gray-50/50 p-6 rounded-3xl border border-gray-100">
        <h3 class="text-xs font-black text-gray-400 uppercase tracking-widest mb-6 border-b pb-4">Informasi Dasar</h3>
        <div class="space-y-6">
          <div>
            <%= f.label :title, "Judul Listing", class: "block text-sm font-bold text-gray-700 mb-2" %>
            <%= f.text_field :title, placeholder: "Contoh: Rumah Minimalis Modern Bangunjiwo", class: "w-full rounded-2xl border-gray-200 focus:ring-blue-500 focus:border-blue-500 py-3 px-4 shadow-sm" %>
          </div>

          <div>
            <%= f.label :description, "Deskripsi Lengkap", class: "block text-sm font-bold text-gray-700 mb-2" %>
            <%= f.text_area :description, rows: 8, placeholder: "Jelaskan kelebihan properti ini secara mendetail...", class: "w-full rounded-2xl border-gray-200 focus:ring-blue-500 focus:border-blue-500 py-3 px-4 shadow-sm resize-none" %>
          </div>
        </div>
      </div>

      <div class="bg-gray-50/50 p-6 rounded-3xl border border-gray-100 font-sans">
        <h3 class="text-xs font-black text-gray-400 uppercase tracking-widest mb-6 border-b pb-4">Spesifikasi Properti</h3>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-6">
          <div>
            <%= f.label :bedrooms, "Kamar Tidur", class: "block text-sm font-bold text-gray-700 mb-2" %>
            <%= f.number_field :bedrooms, class: "w-full rounded-2xl border-gray-200 focus:ring-blue-500 focus:border-blue-500 py-3 px-4 shadow-sm" %>
          </div>
          <div>
            <%= f.label :bathrooms, "Kamar Mandi", class: "block text-sm font-bold text-gray-700 mb-2" %>
            <%= f.number_field :bathrooms, class: "w-full rounded-2xl border-gray-200 focus:ring-blue-500 focus:border-blue-500 py-3 px-4 shadow-sm" %>
          </div>
          <div>
            <%= f.label :floors, "Lantai", class: "block text-sm font-bold text-gray-700 mb-2" %>
            <%= f.number_field :floors, class: "w-full rounded-2xl border-gray-200 focus:ring-blue-500 focus:border-blue-500 py-3 px-4 shadow-sm" %>
          </div>
          <div>
            <%= f.label :building_area, "Luas Bangunan (m²)", class: "block text-sm font-bold text-gray-700 mb-2" %>
            <%= f.number_field :building_area, class: "w-full rounded-2xl border-gray-200 focus:ring-blue-500 focus:border-blue-500 py-3 px-4 shadow-sm" %>
          </div>
          <div>
            <%= f.label :surface_area, "Luas Tanah (m²)", class: "block text-sm font-bold text-gray-700 mb-2" %>
            <%= f.number_field :surface_area, class: "w-full rounded-2xl border-gray-200 focus:ring-blue-500 focus:border-blue-500 py-3 px-4 shadow-sm" %>
          </div>
          <div>
            <%= f.label :certificate_type, "Sertifikat", class: "block text-sm font-bold text-gray-700 mb-2" %>
            <%= f.text_field :certificate_type, placeholder: "SHM / HGB", class: "w-full rounded-2xl border-gray-200 focus:ring-blue-500 focus:border-blue-500 py-3 px-4 shadow-sm" %>
          </div>
        </div>
      </div>

      <div class="bg-gray-50/50 p-6 rounded-3xl border border-gray-100">
        <h3 class="text-xs font-black text-gray-400 uppercase tracking-widest mb-6 border-b pb-4">Harga & Wilayah</h3>
        <div class="grid grid-cols-2 gap-4 mb-4">
          <div>
            <%= f.label :price, "Harga (Rp)", class: "block text-sm font-bold text-gray-700 mb-2" %>
            <%= f.number_field :price, class: "w-full rounded-2xl border-gray-200 focus:ring-blue-500 focus:border-blue-500 py-3 px-4 shadow-sm" %>
          </div>

          <div>
            <%= f.label :region_id, "Wilayah", class: "block text-sm font-bold text-gray-700 mb-2" %>
            <%= f.collection_select :region_id, Region.all, :id, :name, { prompt: "Pilih Wilayah" }, { class: "w-full rounded-2xl border-gray-200 focus:ring-blue-500 focus:border-blue-500 py-3 px-4 shadow-sm" } %>
          </div>
        </div>
        <div>
          <%= f.label :street_address, "Alamat Lengkap", class: "block text-sm font-bold text-gray-700 mb-2" %>
          <%= f.text_field :street_address, placeholder: "Nama jalan, nomor rumah, RT/RW", class: "w-full rounded-2xl border-gray-200 focus:ring-blue-500 focus:border-blue-500 py-3 px-4 shadow-sm" %>
        </div>
      </div>
    </div>

    <!-- Section 2: Details & Media -->
    <div class="space-y-6">
      <div class="bg-gray-50/50 p-6 rounded-3xl border border-gray-100">
        <h3 class="text-xs font-black text-gray-400 uppercase tracking-widest mb-6 border-b pb-4">Klasifikasi</h3>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <%= f.label :listing_type, "Tipe Listing", class: "block text-sm font-bold text-gray-700 mb-2" %>
            <%= f.select :listing_type, Property.listing_types.keys.map { |k| [k.humanize, k] }, {}, class: "w-full rounded-2xl border-gray-200 focus:ring-blue-500 focus:border-blue-500 py-3 px-4 shadow-sm" %>
          </div>
          <div>
            <%= f.label :property_type, "Tipe Properti", class: "block text-sm font-bold text-gray-700 mb-2" %>
            <%= f.select :property_type, Property.property_types.keys.map { |k| [k.humanize, k] }, {}, class: "w-full rounded-2xl border-gray-200 focus:ring-blue-500 focus:border-blue-500 py-3 px-4 shadow-sm" %>
          </div>
        </div>
        <div class="mt-6 flex flex-wrap gap-6 items-end">
          <div class="flex-grow">
            <%= f.label :status, "Status Tayang", class: "block text-sm font-bold text-gray-700 mb-2" %>
            <%= f.select :status, Property.statuses.keys.map { |k| [k.humanize, k] }, {}, class: "w-full rounded-2xl border-gray-200 focus:ring-blue-500 focus:border-blue-500 py-3 px-4 shadow-sm" %>
          </div>
          <% if Current.user.admin? %>
            <div class="pb-2">
              <label class="flex items-center gap-2 cursor-pointer group">
                <%= f.check_box :featured, class: "rounded border-gray-300 text-blue-600 focus:ring-blue-500 w-5 h-5 shadow-sm" %>
                <span class="text-sm font-bold text-orange-600">Jadikan Pilihan Kami ⭐</span>
              </label>
            </div>
          <% end %>
        </div>
      </div>

      
      <!-- Media Section -->
      <div class="p-8 bg-blue-50/50 rounded-[32px] border-2 border-dashed border-blue-200 flex flex-col items-center"
           data-controller="direct-upload">
        <%= label_tag "images_picker", class: "flex flex-col items-center cursor-pointer group" do %>
          <div class="w-16 h-16 bg-blue-600 rounded-3xl flex items-center justify-center text-white mb-4 shadow-xl shadow-blue-200 transform group-hover:-translate-y-1 transition duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
          </div>
          <span class="text-blue-700 font-bold text-lg">Upload Foto Unit</span>
          <span class="text-xs text-blue-400 mt-1 uppercase tracking-widest font-bold">Maksimal 10 File .JPG/.PNG</span>
          <%= file_field_tag "images_picker", 
              multiple: true, 
              accept: 'image/*', 
              direct_upload: true,
              class: "hidden",
              data: { 
                direct_upload_target: "input",
                action: "change->direct-upload#handleFiles direct-upload:initialize->direct-upload#initializeDirectUpload" 
              } %>
        <% end %>

        <div class="mt-8 grid grid-cols-4 gap-3 w-full" data-direct-upload-target="preview">
          <% if property.images.attached? %>
            <% property.images.each do |image| %>
              <div class="aspect-square rounded-2xl overflow-hidden border <%= image.persisted? ? 'border-gray-200' : 'border-green-400' %> shadow-sm relative group">
                <%= image_tag image, class: "w-full h-full object-cover" %>
                
                <%# Kirim ulang ID-nya agar tidak hilang saat submit berikutnya %>
                <%= hidden_field_tag "property[images][]", image.signed_id %>
                
                <div class="absolute top-2 right-2">
                  <span class="<%= image.persisted? ? 'bg-gray-900/40' : 'bg-green-600' %> text-white text-[8px] font-black px-2 py-1 rounded uppercase backdrop-blur-sm">
                    <%= image.persisted? ? 'Saved' : 'Ready' %>
                  </span>
                </div>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>

      <!-- Map Location Helper -->
      <div class="bg-gray-50/50 p-6 rounded-3xl border border-gray-100" 
           data-controller="map-picker"
           data-map-picker-latitude-value="<%= property.lonlat&.y %>"
           data-map-picker-longitude-value="<%= property.lonlat&.x %>">
        <%= f.label :lonlat, "Lokasi di Peta", class: "block text-sm font-bold text-gray-700 mb-2" %>
        
        <div class="w-full h-64 rounded-2xl overflow-hidden shadow-inner border border-gray-200 mb-4 z-0"
             data-map-picker-target="container"></div>
        
        <%= f.text_field :lonlat, 
            placeholder: "POINT(110.3245 -7.8456)", 
            class: "w-full rounded-2xl border-gray-200 bg-gray-100 focus:ring-blue-500 focus:border-blue-500 py-3 px-4 shadow-sm font-mono text-xs",
            data: { map_picker_target: "input" },
            readonly: true %>
            
        <p class="text-[10px] text-gray-400 mt-2 italic">Klik pada peta atau geser marker untuk menentukan lokasi properti secara presisi.</p>
      </div>
    </div>
  </div>

  <div class="pt-10 border-t flex justify-end items-center gap-6">
    <%= link_to "Batalkan", dashboard_properties_path, class: "text-gray-400 font-bold hover:text-gray-600 transition tracking-tight" %>
    <%= f.submit (property.new_record? ? "Terbitkan Listing" : "Simpan Perubahan"), class: "bg-blue-600 hover:bg-blue-700 text-white font-black py-4 px-12 rounded-[24px] shadow-2xl shadow-blue-200 transition transform hover:-translate-y-1 active:translate-y-0" %>
  </div>
<% end %>
