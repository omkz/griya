<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <div class="flex justify-between items-center mb-10">
    <div>
      <h1 class="text-4xl font-black text-gray-900 tracking-tight text-balance">Manajemen Properti</h1>
      <p class="text-gray-500 mt-1">
        <% if Current.user.admin? %>
          Mengelola semua listing di seluruh sistem.
        <% else %>
          Mengelola listing properti Anda sendiri.
        <% end %>
      </p>
    </div>
    <%= link_to "+ Tambah Properti", new_dashboard_property_path, class: "bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-6 rounded-2xl shadow-xl shadow-blue-200 transition transform hover:-translate-y-1" %>
  </div>

  <div class="bg-white rounded-[40px] shadow-2xl shadow-gray-200/50 border border-gray-100 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse">
        <thead class="bg-gray-50/50 border-b border-gray-100">
          <tr>
            <th class="px-8 py-5 text-xs font-bold text-gray-400 uppercase tracking-[0.2em]">Info Properti</th>
            <th class="px-8 py-5 text-xs font-bold text-gray-400 uppercase tracking-[0.2em]">Harga</th>
            <th class="px-8 py-5 text-xs font-bold text-gray-400 uppercase tracking-[0.2em]">Wilayah</th>
            <th class="px-8 py-5 text-xs font-bold text-gray-400 uppercase tracking-[0.2em]">Status</th>
            <th class="px-8 py-5 text-xs font-bold text-gray-400 uppercase tracking-[0.2em] text-right">Aksi</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          <% @properties.each do |property| %>
            <tr class="hover:bg-gray-50/50 transition">
              <td class="px-8 py-6">
                <div class="flex items-center gap-4">
                  <div class="w-16 h-16 rounded-2xl bg-gray-100 overflow-hidden flex-shrink-0">
                    <% if property.images.attached? %>
                      <%= image_tag property.images.first, class: "w-full h-full object-cover" %>
                    <% else %>
                      <div class="w-full h-full flex items-center justify-center text-[10px] text-gray-300 font-bold">N/A</div>
                    <% end %>
                  </div>
                  <div>
                    <p class="font-bold text-gray-900 text-lg leading-tight mb-1"><%= property.title %></p>
                    <div class="flex gap-2">
                       <% if property.featured? %>
                        <span class="text-[8px] font-black bg-orange-100 text-orange-600 px-2 py-0.5 rounded uppercase tracking-tighter">Featured</span>
                      <% end %>
                      <span class="text-[8px] font-black bg-gray-100 text-gray-500 px-2 py-0.5 rounded uppercase tracking-tighter"><%= property.property_type.humanize %></span>
                    </div>
                  </div>
                </div>
              </td>
              <td class="px-8 py-6">
                <p class="font-black text-blue-600 text-lg"><%= number_to_currency(property.price, unit: "Rp ", delimiter: ".", precision: 0) %></p>
                <p class="text-xs text-gray-400 italic"><%= property.listing_type.humanize %></p>
              </td>
              <td class="px-8 py-6">
                <div class="flex items-center gap-1 text-gray-600 font-medium">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  </svg>
                  <%= property.region&.name %>
                </div>
              </td>
              <td class="px-8 py-6">
                <% status_class = case property.status
                   when "active" then "bg-green-100 text-green-700"
                   when "sold", "rented" then "bg-blue-100 text-blue-700"
                   when "draft" then "bg-gray-100 text-gray-500"
                   else "bg-red-100 text-red-700"
                   end
                %>
                <span class="px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest <%= status_class %>">
                  <%= property.status.humanize %>
                </span>
              </td>
              <td class="px-8 py-6 text-right">
                <div class="flex justify-end gap-2">
                  <%= link_to "Edit", edit_dashboard_property_path(property), class: "p-2 text-gray-400 hover:text-blue-600 hover:bg-blue-50 rounded-xl transition" %>
                  <%= button_to "Hapus", [:dashboard, property], method: :delete, data: { confirm: "Yakin?" }, class: "p-2 text-gray-400 hover:text-red-600 hover:bg-red-50 rounded-xl transition" %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
      <% if @properties.empty? %>
        <p class="p-20 text-center text-gray-400 font-medium">Anda belum memiliki properti. Mulai tambah sekarang!</p>
      <% end %>
    </div>
  </div>
</div>
