<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <nav class="mb-6">
    <%= link_to "← Kembali ke List", properties_path, class: "text-blue-600 hover:text-blue-800 font-medium flex items-center gap-1" %>
  </nav>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
    <!-- Left Column: Details & Images -->
    <div class="lg:col-span-2">
      <!-- Main Image -->
      <div class="bg-gray-200 rounded-3xl w-full h-[500px] flex items-center justify-center text-gray-400 font-bold text-2xl shadow-inner mb-4 overflow-hidden relative group">
        <% if @property.images.attached? %>
          <%= image_tag @property.images.first, class: "w-full h-full object-cover" %>
        <% else %>
          <div class="flex flex-col items-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-20 w-20 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
            <span>FOTO BELUM TERSEDIA</span>
          </div>
        <% end %>
      </div>

      <!-- Thumbnail Gallery -->
      <% if @property.images.attached? && @property.images.count > 1 %>
        <div class="flex gap-4 mb-8 overflow-x-auto pb-2">
          <% @property.images.each do |image| %>
            <div class="w-24 h-24 flex-shrink-0 rounded-2xl overflow-hidden border-2 border-transparent hover:border-blue-600 transition cursor-pointer">
              <%= image_tag image, class: "w-full h-full object-cover" %>
            </div>
          <% end %>
        </div>
      <% end %>

      <div class="flex flex-wrap gap-2 mb-4">
        <span class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full text-xs font-bold tracking-wider uppercase"><%= @property.listing_type.humanize %></span>
        <span class="bg-gray-100 text-gray-700 px-3 py-1 rounded-full text-xs font-bold tracking-wider uppercase"><%= @property.property_type.humanize %></span>
        <span class="bg-green-100 text-green-700 px-3 py-1 rounded-full text-xs font-bold tracking-wider uppercase"><%= @property.status.humanize %></span>
      </div>

      <h1 class="text-4xl font-extrabold text-gray-900 mb-2 italic"><%= @property.title %></h1>
      <p class="text-xl text-gray-500 mb-6 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        <%= @property.region.name %>, DI Yogyakarta
      </p>

      <div class="border-t border-b py-8 mb-8">
        <h3 class="text-2xl font-bold mb-4">Deskripsi</h3>
        <div class="prose prose-blue max-w-none text-gray-700 leading-relaxed mb-8">
          <%= simple_format @property.description %>
        </div>

        <% if @property.lonlat %>
          <h3 class="text-2xl font-bold mb-4">Lokasi</h3>
          <div class="w-full h-80 rounded-3xl overflow-hidden shadow-inner border border-gray-100 z-0"
               data-controller="map"
               data-map-latitude-value="<%= @property.lonlat.y %>"
               data-map-longitude-value="<%= @property.lonlat.x %>"
               data-map-title-value="<%= @property.title %>">
          </div>
        <% end %>
      </div>
    </div>

    <!-- Right Column: Pricing & Contact -->
    <div class="lg:col-span-1">
      <div class="sticky top-24 space-y-6">
        <div class="bg-white border border-gray-100 rounded-[40px] p-8 shadow-2xl shadow-gray-200/50">
          <div class="mb-2 text-center text-balance">
            <p class="text-xs text-gray-400 font-bold uppercase tracking-[0.2em] mb-1">Harga Penawaran</p>
            <p class="text-4xl font-black text-blue-600">
              <%= number_to_currency(@property.price, unit: "Rp ", delimiter: ".", precision: 0) %>
            </p>
          </div>

          <div class="my-8 h-px bg-gray-100"></div>

          <div class="mb-8">
            <div class="flex items-center gap-4 mb-6 pt-2">
              <div class="w-14 h-14 bg-gradient-to-br from-blue-600 to-blue-700 rounded-2xl flex items-center justify-center text-white text-xl font-bold shadow-lg">
                <%= @property.user.email_address[0].upcase %>
              </div>
              <div>
                <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest">Agen Verifikasi</p>
                <p class="font-bold text-gray-900 text-lg"><%= @property.user.email_address.split('@').first.capitalize %></p>
              </div>
            </div>

            <a href="https://wa.me/628123456789?text=Halo, saya tertarik dengan properti: <%= @property.title %>" 
               target="_blank"
               class="w-full flex items-center justify-center gap-3 bg-green-500 hover:bg-green-600 text-white font-bold py-4 px-6 rounded-2xl transition-all transform hover:scale-[1.02] active:scale-[0.98] shadow-xl shadow-green-100 text-balance">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
                <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.417-.003 6.557-5.338 11.892-11.893 11.892-1.997-.001-3.951-.5-5.688-1.448l-6.305 1.652zm6.599-3.835c1.474.875 3.183 1.338 4.925 1.339 5.233 0 9.493-4.259 9.495-9.493 0-2.536-1-4.92-2.817-6.738-1.817-1.817-4.201-2.817-6.738-2.817-5.231 0-9.491 4.259-9.494 9.493-.001 1.847.532 3.649 1.54 5.207l-.986 3.601 3.687-.967zm12.332-6.502c-.06-.1-.219-.159-.46-.278-.24-.12-1.418-.7-1.638-.78-.221-.08-.381-.12-.541.12-.16.24-.621.78-.761.939-.14.16-.279.18-.52.06-.24-.12-.862-.318-1.583-.961-.561-.5-1.033-.1.115-1.411-.3-.379.083-.7-.241-.44-.241-.34-.86-.16-1.1s-.418-.12-.541.12c-.12.24-.46.78-.46.78s.16.44.4.659c.241.219.48.439.54.439.06 0 .219-.06.46-.24.239-.18.418-.419.418-.419.06-.06.12-.1.18-.1.06 0 .12 0 .18.04s.48.24.48.24.12.06.18.12c.06.06.06.18.02.3-.06.12-.24.3-.42.48s-.421.36-.66.36c-.24 0-.48-.06-.72-.18-.24-.12-.48-.3-.66-.48s-.36-.42-.5-.66c-.14-.24-.26-.48-.34-.74-.08-.26-.14-.5-.14-.72 0-.22.06-.44.18-.66.12-.22.3-.42.48-.6s.36-.36.54-.48c.18-.12.3-.18.3-.18s.1-.119.14-.159c.04-.04.04-.1.02-.16s-.14-.34-.239-.56c-.1-.22-.199-.44-.26-.6-.06-.16-.14-.18-.3-.18s-.24 0-.42.06c-.18.06-.42.18-.62.38s-.44.5-.44 1.1c0 .6.44 1.18.5 1.259.06.08.859 1.314 2.083 1.841 1.224.527 1.224.351 1.444.331.22-.02.7-.28.8-.56.1-.28.1-.52.06-.56-.04-.04-.16-.1-.4-.22z"/>
              </svg>
              Chat via WhatsApp
            </a>
          </div>
        </div>

        <% if authenticated? && (Current.user == @property.user || Current.user.admin?) %>
          <div class="bg-gray-900 border border-gray-800 rounded-3xl p-6 shadow-xl">
            <p class="text-xs text-gray-500 font-bold uppercase tracking-widest mb-4">Administrasi</p>
            <div class="grid grid-cols-2 gap-3 text-balance">
              <%= link_to edit_dashboard_property_path(@property), class: "flex items-center justify-center gap-2 bg-gray-800 hover:bg-gray-700 text-white font-bold py-3 rounded-xl transition shadow-sm" do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                </svg>
                Edit
              <% end %>
              <%= button_to [:dashboard, @property], method: :delete, data: { confirm: "Yakin ingin menghapus listing ini?" }, class: "w-full flex items-center justify-center gap-2 bg-red-900/30 hover:bg-red-900/50 text-red-500 font-bold py-3 rounded-xl transition border border-red-900/50" do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                </svg>
                Hapus
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
