<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <nav class="mb-6">
    <%= link_to "← Kembali ke List", properties_path, class: "text-blue-600 hover:text-blue-800 font-medium flex items-center gap-1" %>
  </nav>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
    <div class="lg:col-span-2">
      <div data-controller="gallery" data-gallery-active-class="border-blue-600">
        <!-- Main Image -->
        <div class="bg-gray-200 rounded-3xl w-full h-[500px] flex items-center justify-center text-gray-400 font-bold text-2xl shadow-inner mb-4 overflow-hidden relative group">
          <% if @property.images.attached? %>
            <%= image_tag @property.images.first.variant(:large), 
                class: "w-full h-full object-cover transition-opacity duration-300", 
                loading: "eager",
                data: { gallery_target: "main" } %>
          <% else %>
            <div class="flex flex-col items-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-20 w-20 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
              </svg>
              <span>FOTO BELUM TERSEDIA</span>
            </div>
          <% end %>
        </div>

        <!-- Thumbnail Gallery -->
        <% if @property.images.attached? && @property.images.count > 1 %>
          <div class="flex gap-4 mb-8 overflow-x-auto pb-2 scrollbar-hide">
            <% @property.images.each_with_index do |image, index| %>
              <div class="w-24 h-24 flex-shrink-0 rounded-2xl overflow-hidden border-2 transition cursor-pointer <%= index == 0 ? "border-blue-600" : "border-transparent" %>"
                   data-gallery-target="thumbnail"
                   data-action="click->gallery#select"
                   data-src="<%= url_for(image.variant(:large)) %>">
                <%= image_tag image.variant(:thumbnail), 
                    class: "w-full h-full object-cover pointer-events-none",
                    loading: "lazy" %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>

      <div class="flex flex-wrap gap-2 mb-4">
        <span class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full text-xs font-bold tracking-wider uppercase"><%= @property.listing_type.humanize %></span>
        <span class="bg-gray-100 text-gray-700 px-3 py-1 rounded-full text-xs font-bold tracking-wider uppercase"><%= @property.property_type.humanize %></span>
        <span class="bg-green-100 text-green-700 px-3 py-1 rounded-full text-xs font-bold tracking-wider uppercase"><%= @property.status.humanize %></span>
      </div>

      <h1 class="text-4xl font-extrabold text-gray-900 mb-2 italic"><%= @property.title %></h1>
      <p class="text-gray-500 flex items-center gap-2 mb-8 font-medium">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
        </svg>
        <%= @property.street_address.presence || "#{@property.region.name}, DI Yogyakarta" %>
      </p>

      <div class="mb-10 grid grid-cols-2 md:grid-cols-4 gap-4">
        <% if @property.bedrooms > 0 %>
          <div class="bg-blue-50/50 p-4 rounded-3xl border border-blue-100/50 flex flex-col items-center text-center">
             <span class="text-2xl mb-1">🛏️</span>
             <span class="text-sm font-black text-blue-900"><%= @property.bedrooms %> Kamar</span>
          </div>
        <% end %>
        <% if @property.bathrooms > 0 %>
          <div class="bg-blue-50/50 p-4 rounded-3xl border border-blue-100/50 flex flex-col items-center text-center">
             <span class="text-2xl mb-1">🚿</span>
             <span class="text-sm font-black text-blue-900"><%= @property.bathrooms %> Mandi</span>
          </div>
        <% end %>
        <% if @property.building_area.present? %>
          <div class="bg-blue-50/50 p-4 rounded-3xl border border-blue-100/50 flex flex-col items-center text-center">
             <span class="text-2xl mb-1">🏠</span>
             <span class="text-sm font-black text-blue-900"><%= @property.building_area %> m²</span>
             <span class="text-[9px] text-blue-400 font-bold uppercase tracking-tighter">Luas Bangunan</span>
          </div>
        <% end %>
        <% if @property.surface_area.present? %>
          <div class="bg-blue-50/50 p-4 rounded-3xl border border-blue-100/50 flex flex-col items-center text-center">
             <span class="text-2xl mb-1">📐</span>
             <span class="text-sm font-black text-blue-900"><%= @property.surface_area %> m²</span>
             <span class="text-[9px] text-blue-400 font-bold uppercase tracking-tighter">Luas Tanah</span>
          </div>
        <% end %>
      </div>

      <div class="border-t border-b py-8 mb-8">
        <div class="grid grid-cols-2 gap-8 mb-8">
           <div>
             <h4 class="text-xs font-black text-gray-400 uppercase tracking-widest mb-1">Sertifikat</h4>
             <p class="font-bold text-gray-900"><%= @property.certificate_type.presence || "N/A" %></p>
           </div>
           <div>
             <h4 class="text-xs font-black text-gray-400 uppercase tracking-widest mb-1">Lantai</h4>
             <p class="font-bold text-gray-900"><%= @property.floors %> Lantai</p>
           </div>
        </div>
        
        <h3 class="text-2xl font-bold mb-4">Deskripsi</h3>
        <div class="prose prose-blue max-w-none text-gray-700 leading-relaxed mb-8">
          <%= simple_format @property.description %>
        </div>

        <% if @property.lonlat %>
          <h3 class="text-2xl font-bold mb-4">Lokasi</h3>
          <div class="w-full h-80 rounded-3xl overflow-hidden shadow-inner border border-gray-100 z-0"
               data-controller="map"
               data-map-latitude-value="<%= @property.lonlat.y %>"
               data-map-longitude-value="<%= @property.lonlat.x %>"
               data-map-title-value="<%= @property.title %>">
          </div>
        <% end %>
      </div>
    </div>

    <!-- Right Column: Pricing & Contact -->
    <div class="lg:col-span-1">
      <div class="sticky top-24 space-y-6">
        <div class="bg-white border border-gray-100 rounded-[40px] p-8 shadow-2xl shadow-gray-200/50">
          <div class="mb-2 text-center text-balance">
            <p class="text-xs text-gray-400 font-bold uppercase tracking-[0.2em] mb-1">Harga Penawaran</p>
            <p class="text-4xl font-black text-blue-600">
              <%= number_to_currency(@property.price, unit: "Rp ", delimiter: ".", precision: 0) %>
            </p>
          </div>

          <div class="my-8 h-px bg-gray-100"></div>

          <div class="mb-8">
            <div class="flex items-center gap-4 mb-6 pt-2">
              <div class="w-14 h-14 bg-gradient-to-br from-blue-600 to-blue-700 rounded-2xl flex items-center justify-center text-white text-xl font-bold shadow-lg">
                <%= @property.user.email_address[0].upcase %>
              </div>
              <div>
                <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest">Agen Verifikasi</p>
                <p class="font-bold text-gray-900 text-lg"><%= @property.user.email_address.split('@').first.capitalize %></p>
              </div>
            </div>

            <a href="https://wa.me/628123456789?text=Halo, saya tertarik dengan properti: <%= @property.title %>" 
               target="_blank"
               class="w-full flex items-center justify-center gap-3 bg-green-500 hover:bg-green-600 text-white font-bold py-4 px-6 rounded-2xl transition-all transform hover:scale-[1.02] active:scale-[0.98] shadow-xl shadow-green-100 text-balance">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Chat via WhatsApp
            </a>
          </div>
        </div>

        <% if authenticated? && (Current.user == @property.user || Current.user.admin?) %>
          <div class="bg-gray-900 border border-gray-800 rounded-3xl p-6 shadow-xl">
            <p class="text-xs text-gray-500 font-bold uppercase tracking-widest mb-4">Administrasi</p>
            <div class="grid grid-cols-2 gap-3 text-balance">
              <%= link_to edit_dashboard_property_path(@property), class: "flex items-center justify-center gap-2 bg-gray-800 hover:bg-gray-700 text-white font-bold py-3 rounded-xl transition shadow-sm" do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                </svg>
                Edit
              <% end %>
              <%= button_to [:dashboard, @property], method: :delete, data: { confirm: "Yakin ingin menghapus listing ini?" }, class: "w-full flex items-center justify-center gap-2 bg-red-900/30 hover:bg-red-900/50 text-red-500 font-bold py-3 rounded-xl transition border border-red-900/50" do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                </svg>
                Hapus
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
