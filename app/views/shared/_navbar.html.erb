    <div class="flex justify-between h-16">
      <div class="flex items-center">
        <%= link_to root_path, class: "flex-shrink-0 flex items-center gap-2" do %>
          <span class="text-2xl font-bold text-blue-600">GRIYA</span>
        <% end %>

        <div class="hidden sm:ml-8 sm:flex sm:space-x-8">
          <%= link_to "Find Home", properties_path, class: "text-gray-600 hover:text-blue-600 px-3 py-2 text-sm font-medium" %>
