        <% else %>
          <%= link_to "Sign In", new_session_path, class: "text-sm font-medium text-gray-700 hover:text-blue-600" %>
          <%# link_to "Register", new_session_path, class: "bg-blue-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-blue-700 transition" %>
        <% end %>
      </div>
