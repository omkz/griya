<% flash.each do |type, message| %>
  <div class="mb-4 rounded-lg p-4 text-sm shadow-lg <%= type == 'notice' ? 'bg-green-100 text-green-700 border border-green-200' : 'bg-red-100 text-red-700 border border-red-200' %>"
       data-controller="flash"
       data-action="transition-end->flash#remove">
    <%= message %>
  </div>
<% end %>
